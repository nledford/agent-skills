{
  "$schema": "https://opencode.ai/config.json",

  // Merge into the machine-local opencode.jsonc; do not replace credentials,
  // providers, plugins, or other local configuration.
  "default_agent": "engineering-lead"

  /*
  MCP server installation and credentials remain machine-local. Configure the
  official GitHub MCP server with its upstream read-only mode by default. The
  checked-in Lead and Worker definitions still ask-gate every configured MCP
  prefix; enabling a write-capable server does not authorize a remote mutation.
  Any mutation needs exact current human authority plus runtime approval.
  */

  /*
  Optional per-agent external-audit override. Replace the placeholder with one
  trusted machine-local root, keep the catch-all rule first, and repeat the
  permission block for every agent or subagent that needs the same scope.

  "agent": {
    "engineering-review-board": {
      "permission": {
        "external_directory": {
          "*": "deny",
          "~/projects/<external-project>": "ask",
          "~/projects/<external-project>/**": "ask"
        }
      }
    }
  }
  */
}
